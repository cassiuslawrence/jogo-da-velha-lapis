<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Splash screen for Android 12+ (API 31+).
         Theme.SplashScreen on API 31+ ignores android:background —
         background and icon must be set via windowSplashScreen* attributes. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">#f5f0e8</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
    </style>

</resources>
